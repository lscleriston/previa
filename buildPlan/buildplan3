### 3.4 Docker
Crie `Dockerfile` e `docker-compose.yml`:

```dockerfile
# Dockerfile — multi-stage
FROM python:3.12-slim AS backend
WORKDIR /app
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY backend/ .
EXPOSE 8000
CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
```

```yaml
# docker-compose.yml
version: "3.9"
services:
  backend:
    build: .
    ports:
      - "8000:8000"
    volumes:
      - ./data:/app/data          # xlsx e forecast.db ficam aqui
      - ./backend:/app            # hot reload no desenvolvimento
    environment:
      - XLSX_PATH=/app/data/forecast.xlsx
      - DB_PATH=/app/data/forecast.db
  
  frontend:
    image: nginx:alpine
    ports:
      - "3000:80"
    volumes:
      - ./frontend:/usr/share/nginx/html
```

